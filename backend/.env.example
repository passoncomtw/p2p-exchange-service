# ============================================================
# P2P Exchange Service — 後端環境變數範本
# 複製為 .env 並填入實際值（.env 不進 git）
# ============================================================

# Redis
REDIS_ADDR=localhost:30379
REDIS_PASSWORD=

# NATS
NATS_URL=nats://localhost:30422
NATS_USER=
NATS_PASSWORD=

# Tron 熱錢包（v0.3.0）
# Network: nile（測試網）or mainnet
# 敏感欄位請勿 commit，透過 CI/CD Secret 注入
TRON_GRID_URL=https://nile.trongrid.io
TRON_GRID_API_KEY=
TRON_HOT_WALLET_ADDRESS=
TRON_HOT_WALLET_PRIVATE_KEY=

# ECPay 金流（v0.3.0）
# 測試環境：HashKey=5294y06JbISpM5x9、HashIV=v77hoKGq4kWxNNIS（綠界測試帳號固定值）
# 生產環境請透過 CI/CD Secret 注入，勿 commit 至 git
ECPAY_HASH_KEY=
ECPAY_HASH_IV=
ECPAY_RETURN_URL=
ECPAY_CLIENT_BACK_URL=
