Name: p2p-api
Host: 0.0.0.0
Port: 8888

App:
  AccessSecret: "replace-with-random-secret"
  AccessExpire: 86400

Backend:
  AccessSecret: "replace-with-another-random-secret"
  AccessExpire: 86400

Database:
  DSN: "postgresql://user:password@host/dbname?sslmode=require"

Redis:
  Addr: "localhost:6379"
  Password: ""
  PoolSize: 10

Nats:
  URL: "nats://localhost:4222"
  User: ""
  Password: ""
  CredsPath: ""
  StreamName: "p2p-exchange"
  ConsumerName: "p2p-exchange-consumer"
