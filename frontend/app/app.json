{
  "expo": {
    "name": "E幣錢包",
    "slug": "token-app-service",
    "version": "0.2.2",
    "orientation": "portrait",
    "icon": "./src/assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "tokenappservice",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.passon.ecoinwallet",
      "icon": "./src/assets/images/ios-icon.png",
      "buildNumber": "7",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.passon.ecoinwallet",
      "versionCode": 7,
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/images/adaptive-icon.png",
        "backgroundColor": "#7B68C8"
      },
      "icon": "./src/assets/images/android-icon.png"
    },
    "web": {
      "favicon": "./src/assets/images/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      "expo-asset",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#7B68C8",
          "image": "./src/assets/images/icon.png",
          "imageWidth": 200
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./src/assets/images/icon.png",
          "color": "#7B68C8",
          "defaultChannel": "orders"
        }
      ],
      "./plugins/withPodfilePostInstall",
      "expo-image",
      "expo-web-browser",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "869a711e-70db-4ee7-9c62-bda2aec26ce0"
      }
    }
  }
}
