{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "moduleResolution": "bundler",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@pkg/*": [
        "./src/pkg/*"
      ],
      "@frontend-pkg/*": [
        "../pkg/*"
      ],
      "@shared": [
        "../shared/src/index.ts"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ]
}
